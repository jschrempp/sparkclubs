# Database Configuration (Local Development - MySQL)
DB_NAME=bookclubs_db
DB_USER=bookclubs_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=3306

# Production Database (Railway provides this automatically)
# DATABASE_URL=postgresql://user:password@host:port/database

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production Settings (Railway)
# RAILWAY_STATIC_URL will be set automatically by Railway
# PRODUCTION_HOST=yourdomain.com

# CORS Settings (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production: CORS_ALLOWED_ORIGINS=https://your-frontend.railway.app,https://yourdomain.com

# CSRF Settings (comma-separated list)
CSRF_TRUSTED_ORIGINS=http://localhost:3000
# Production: CSRF_TRUSTED_ORIGINS=https://your-frontend.railway.app,https://yourdomain.com

# Authentication Configuration
# Set to True to enable Google OAuth, False for traditional email/password authentication
USE_GOOGLE_OAUTH=False

# Google OAuth Configuration (only required if USE_GOOGLE_OAUTH=True)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:3000

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# OpenAI API Key for Book Recommendations
OPENAI_API_KEY=your-openai-api-key-here
