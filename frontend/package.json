{
  "name": "bookclubs-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "react-scripts": "5.0.1",
    "@react-oauth/google": "^0.12.1",
    "axios": "^1.6.5",
    "date-fns": "^3.0.6",
    "serve": "^14.2.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "node generate-version.js && echo '\n=== BUILD COMPLETE ===' && cat src/version.json && echo '==================\n' && react-scripts build",
    "preserve": "echo '\n========== STARTING SERVER ==========' && echo 'Deployed Version:' && cat build/../src/version.json && echo '====================================\n'",
    "serve": "serve -s build -l $PORT",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
