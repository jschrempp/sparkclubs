{
  "name": "bookclubs-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.21.0",
    "@react-oauth/google": "^0.12.1",
    "axios": "^1.6.5",
    "date-fns": "^3.0.6",
    "@tanstack/react-query": "^5.62.0",
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "node generate-version.cjs && vite build",
    "preview": "vite preview",
    "preserve": "echo '\n========== STARTING SERVER ==========' && echo 'Deployed Version:' && cat dist/version.json 2>/dev/null || echo 'No version.json found' && echo '====================================\n'",
    "serve": "serve -s dist -l $PORT",
    "test": "echo \"No tests configured yet\"",
    "eject": "echo \"eject is not available with Vite\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
