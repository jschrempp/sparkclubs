# Frontend Environment Variables (Vite — must be prefixed with VITE_)
VITE_API_URL=http://localhost:8000/api

# Authentication Configuration
# Set to true to enable Google OAuth, false for traditional email/password authentication
VITE_USE_GOOGLE_OAUTH=false

# Google OAuth Configuration (only required if VITE_USE_GOOGLE_OAUTH=true)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
